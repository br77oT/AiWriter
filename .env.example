# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit real secrets.

# Anthropic API key (https://console.anthropic.com/) or an OAuth token
# from a Claude subscription (sk-ant-oat… prefix).
ANTHROPIC_API_KEY=

# Optional. Personal access token used by gh CLI for issue / PR commands.
GH_TOKEN=
